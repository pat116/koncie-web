# apps/web env — mirrors root .env.example for convenience.
# Local dev: copy to .env.local (gitignored).
# Staging/prod: set in Vercel dashboard.

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Sprint 6 completion (Twilio SMS, chat surface, JetSeeker webhook) ──

# Twilio trial — verified-numbers allowlist required by trial.
KONCIE_TWILIO_MODE=sandbox
KONCIE_TWILIO_ACCOUNT_SID=
KONCIE_TWILIO_AUTH_TOKEN=
KONCIE_TWILIO_FROM_NUMBER=
# Comma-separated E.164. Only enforced in live mode. Sandbox skips the guard.
KONCIE_TWILIO_ALLOWLIST=

# 32+ chars. Used for both chat tokens (no origin) and bridge tokens
# (with origin). Same secret for both — one mint/verify code path.
KONCIE_CHAT_TOKEN_SECRET=

# JetSeeker time-change webhook HMAC secret. Sprint-7 wire-up replaces
# the placeholder with the real value from the Symfony team.
KONCIE_JETSEEKER_WEBHOOK_SECRET=

# Vercel cron bearer token. Already used by /api/cron/pre-arrival.
CRON_SECRET=
