# Copy this file to .env.local for local dev.
# Never commit real secrets — use Vercel env vars for staging/production.

# ─── Sentry (Sprint 0) ─────────────────────────────────────────────────
# Server-side DSN. Used by Sentry's Next.js SDK for server + edge contexts.
SENTRY_DSN=

# Public DSN. Used by Sentry's browser client. Can be the same value as SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: auth token + org/project slugs for source-map uploads on build.
# Only needed if you wire up the Sentry build plugin.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Sprint 1+ (not used yet, placeholders only) ───────────────────────
# Clerk (auth)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Resend (email)
RESEND_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Postgres (Supabase or RDS — decision per Sprint 0 checkpoint)
DATABASE_URL=
DIRECT_URL=
